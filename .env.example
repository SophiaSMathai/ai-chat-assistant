# Copy this file to `.env` and fill in your real key.
# NEVER commit the real `.env` file — it's already in .gitignore.

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite
# Comma-separated list of frontend origins allowed to call this API.
# Add your deployed frontend URL here once you have it, e.g.:
# ALLOWED_ORIGINS=http://localhost:5500,https://nova-frontend.onrender.com
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
